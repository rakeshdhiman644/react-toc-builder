{
  "name": "react-toc-builder",
  "version": "2.2.2",
  "description": "A lightweight React Table of Contents generator",
  "author": "Rakesh Dhiman",
  "license": "MIT",
  "main": "dist/index.cjs.js",
  "module": "dist/index.esm.js",
  "types": "src/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.esm.js",
      "require": "./dist/index.cjs.js"
    },
    "./styles.css": "./styles.css"
  },
  "files": [
    "dist",
    "demo",
    "src/index.d.ts",
    "styles.css"
  ],
  "scripts": {
    "build": "rollup -c",
    "prepare": "npm run build"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.0.0",
    "@babel/preset-react": "^7.0.0",
    "@rollup/plugin-babel": "^6.0.0",
    "@rollup/plugin-commonjs": "^25.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "babel-core": "^7.0.0-bridge.0",
    "baseline-browser-mapping": "^2.10.32",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "rollup": "^3.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/rakeshdhiman644/react-toc-builder.git"
  },
  "homepage": "https://github.com/rakeshdhiman644/react-toc-builder",
  "bugs": {
    "url": "https://github.com/rakeshdhiman644/react-toc-builder/issues"
  },
  "keywords": [
    "react",
    "toc",
    "table-of-contents",
    "table of contents",
    "react toc",
    "react table of contents",
    "html",
    "generator",
    "navigation",
    "sidebar",
