    "documentation",
    "blog",
    "content",
    "markdown",
    "headings",
    "h2",
    "h3",
    "h4",
    "h5",
    "h6",
    "collapsible",
    "toggle",
    "lightweight",
    "component",
    "library",
    "npm",
    "javascript",
    "jsx",
    "frontend",
    "ui",
    "widget",
    "scrollspy",
    "anchor links",
    "auto toc",
    "react plugin",
    "react widget"
  ],
  "dependencies": {
    "dompurify": "^3.4.5"
  }
}